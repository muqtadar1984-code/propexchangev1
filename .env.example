# ── Streamlit Backend (app.py) ────────────────────────────────────────────────
# Leave empty for local dev (api_server runs as background thread on port 8502)
# Set to your Railway URL for cloud deployment:
#   TWINVAL_API_URL=https://twinval-api.up.railway.app
TWINVAL_API_URL=

# ── React Frontend (frontend/.env.local) ──────────────────────────────────────
# Leave empty for local dev (Vite proxies /api → localhost:8502)
# Set to your Railway URL in Vercel environment variables:
#   VITE_API_URL=https://twinval-api.up.railway.app
VITE_API_URL=
